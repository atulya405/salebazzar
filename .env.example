APP_NAME=Salebazzar
APP_ENV=development
CONTACT_EMAIL=
DATABASE_URL=sqlite:///./80off.db
SCAN_INTERVAL_MINUTES=1080
RUN_SCAN_ON_STARTUP=false
REQUEST_TIMEOUT_SECONDS=15
MAX_RESULTS_PER_CATEGORY=40
MAX_DEALS_PER_CATEGORY=50
MIN_DEAL_QUALITY_SCORE=48
DEAL_RETENTION_HOURS=24

# Comma-separated. These defaults match the six storefront sections.
CATEGORIES=Electronics,Fashion,Home & Kitchen,Beauty,Sports,Books

# SerpApi Google Shopping
SERPAPI_ENABLED=false
SERPAPI_KEY=
SERPAPI_COUNTRY=in
SERPAPI_LANGUAGE=en
SERPAPI_GOOGLE_DOMAIN=google.co.in
SERPAPI_MONTHLY_SEARCH_LIMIT=250
SERPAPI_MONTHLY_SEARCH_RESERVE=10

# DataYuge plans may use different catalog/search endpoints. Configure the
# licensed endpoint exposed by your account. It must accept query and api_key.
DATAYUGE_ENABLED=false
DATAYUGE_API_KEY=
DATAYUGE_SEARCH_URL=

# PricesAPI plans may use different product-search endpoints. Configure the
# licensed endpoint exposed by your account. It must accept query and api_key.
PRICESAPI_ENABLED=false
PRICESAPI_API_KEY=
PRICESAPI_SEARCH_URL=

# Optional affiliate rewriting. Use {url} for the URL-encoded destination and
# {tag} for the configured affiliate ID.
AMAZON_AFFILIATE_TAG=
FLIPKART_AFFILIATE_TAG=
OTHER_AFFILIATE_TEMPLATE=
OTHER_AFFILIATE_TAG=
